* text=auto

*.bat text eol=crlf
*.ps1 text eol=crlf
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

*.7z binary
*.dds binary
*.doc binary
*.docx binary
*.fbx binary
*.ico binary
*.jpg binary
*.mdb binary
*.MDB binary
*.pdf binary
*.png binary
*.zip binary

# Storefront/model repository payloads can become large quickly.
model-repository/packages/*.zip filter=lfs diff=lfs merge=lfs -text
model-repository/outfits/**/*.dds filter=lfs diff=lfs merge=lfs -text
model-repository/outfits/**/*.DDS filter=lfs diff=lfs merge=lfs -text
model-repository/outfits/**/*.fbx filter=lfs diff=lfs merge=lfs -text
model-repository/outfits/**/*.FBX filter=lfs diff=lfs merge=lfs -text
model-repository/outfits/**/*.mdb filter=lfs diff=lfs merge=lfs -text
model-repository/outfits/**/*.MDB filter=lfs diff=lfs merge=lfs -text
